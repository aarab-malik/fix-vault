# Copy to backend/.env then fill the blanks.

# Supabase Connect → URI. Replace PASSWORD. Keep +asyncpg only on DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Run: python scripts/generate_key.py  → paste below. JWT_SECRET = any long random string.
JWT_SECRET=
CREDENTIALS_ENCRYPTION_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:3000

# Gemini (users still paste their own key in Settings)
CHAT_MODEL=gemini-flash-latest
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
DEFAULT_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
