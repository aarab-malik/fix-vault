# Copy to backend/.env then fill the blanks.

# Local: direct connection is fine.
# Vercel/cloud: use Supabase Connection pooling → Transaction mode (port 6543).
# Keep +asyncpg only on DATABASE_URL. URL-encode special characters in PASSWORD.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Run: python scripts/generate_key.py  → paste below. JWT_SECRET = any long random string.
JWT_SECRET=
CREDENTIALS_ENCRYPTION_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Local: COOKIE_SECURE=false. Vercel (HTTPS): COOKIE_SECURE=true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Local: http://localhost:3000
# Production: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000

# Gemini (users still paste their own key in Settings)
CHAT_MODEL=gemini-flash-latest
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
DEFAULT_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
